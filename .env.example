# Copy to ".env" and adjust. Prefix for app settings: ASC_

# API bearer token (required in production)
ASC_API_TOKEN=change-me

# Data directory (SQLite events, media paths)
ASC_DATA_DIR=./data

# Ollama (VLM)
ASC_OLLAMA_BASE_URL=http://127.0.0.1:11434
ASC_OLLAMA_MODEL=llava

# Optional: ntfy topic URL (e.g. https://ntfy.sh/your-topic or self-hosted)
# ASC_NTFY_TOPIC_URL=https://ntfy.sh/your-secret-topic

# Optional: go2rtc HTTP API (for future stream control)
# ASC_GO2RTC_API_URL=http://127.0.0.1:1984
